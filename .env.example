# ============================================================
# Base de datos Turso (OBLIGATORIO para que se guarden los datos)
# Crea una base de datos gratis en https://turso.tech y copia aqui:
#   1. La URL de la base de datos (empieza por libsql://)
#   2. El token de acceso
# En Vercel: Settings -> Environment Variables -> anade estas dos.
# ------------------------------------------------------------
TURSO_DATABASE_URL=libsql://tu-database-tu-org.turso.io
TURSO_AUTH_TOKEN=tu-token-aqui

# ============================================================
# Asistente de IA (OPCIONAL)
# Sin esto, el asistente funciona en modo offline (respuestas por temas).
# Con una clave, el asistente razona de verdad usando tu catalogo y la normativa.
# ------------------------------------------------------------
# Clave de OpenAI (unica obligatoria para activar la IA)
OPENAI_API_KEY=
# Modelo a usar (opcional, por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# URL base del proveedor (opcional, para usar otro compatible con OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# Diagnostico de base de datos /api/health/db (SEC-001)
# Sin esta variable, el endpoint queda deshabilitado (404) por defecto.
# Si se define, hay que enviar el mismo valor en la cabecera
# "x-health-check-secret" para poder usar el endpoint.
# ------------------------------------------------------------
HEALTH_CHECK_SECRET=

# ============================================================
# Exportaciones /api/export/* (SEC-002)
# Sin esta variable, los endpoints de exportacion quedan deshabilitados (404).
# Si se define, hay que enviar el mismo valor en la cabecera
# "x-export-secret" para poder descargar los datos.
# ------------------------------------------------------------
EXPORT_SECRET=

# ============================================================
# Asistente de IA /api/assistant (SEC-003A)
# Sin esta variable, el endpoint queda deshabilitado (404) y NO se llama a
# OpenAI. Si se define, hay que enviar el mismo valor en la cabecera
# "x-ai-secret" para poder usar el asistente.
# ------------------------------------------------------------
AI_SECRET=

# ============================================================
# Proteccion global de la app con Basic Auth (SEC-004B)
# Sin estas 2 variables, TODA la app queda bloqueada (503) por seguridad.
# Con ambas definidas, el navegador pedira usuario y contrasena antes de
# mostrar cualquier pagina o API.
# ------------------------------------------------------------
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=

# ============================================================
# Modo demostración comercial (DEMO-DASH-001)
# Activa datos ficticios únicamente para demostraciones comerciales.
# No escribe registros en la base de datos.
# No activar en producción.
# ------------------------------------------------------------
DEMO_MODE=false
